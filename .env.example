# ── SMTP (email reporter) ─────────────────────────────────────────────────────
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=YOUR_SMTP_USER
SMTP_PASS=YOUR_SMTP_PASS
SMTP_FROM_EMAIL=noreply@yourdomain.com

# ── App credentials ───────────────────────────────────────────────────────────
APP_USERNAME=your-login-email@example.com
APP_PASSWORD=your-app-password

# ── Test data ─────────────────────────────────────────────────────────────────
TEST_COMPANY=Your Company Name
TEST_ADDRESS1=123 Main St
TEST_ADDRESS2=#100
TEST_CITY=Your City
TEST_STATE=Your State
TEST_ZIP=00000
TEST_COUNTRY=USA
TEST_CARD_NUMBER=4111111111111111
TEST_CARD_EXPIRY=12/40
TEST_CARD_CVV=123
TEST_EMAIL=qa@yourdomain.com

# ── URLs ──────────────────────────────────────────────────────────────────────
BASE_URL=https://devbox.gagediamonds.com
SECURE_URL=https://securedev.gagediamonds.com
ENV_URL=https://devbox.gagediamonds.com/